    "scopeNote": "A comparative assessment of selected major frontier-AI jurisdictions, not a complete global measurement."
  },
  "definition": "Governance of general-purpose AI models with advanced capabilities or systemic-risk potential, particularly model evaluation, technical documentation, incident reporting, regulatory access, risk mitigation, and enforcement.",
  "scope": {
    "included": [
      "General-purpose and frontier models",
      "Model evaluations",
      "Technical and training documentation",
      "Serious-incident reporting",
      "Government access to technical information",
      "Independent testing and auditing",
      "Corrective and enforcement powers"
    ],
    "excluded": [
      "Sector-specific AI uses such as healthcare or hiring",
      "General data protection",
      "Military deployment",
      "Ordinary software cybersecurity",
      "Universities and academic institutions"
    ]
  },
